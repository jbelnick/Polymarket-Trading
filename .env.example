# Kalshi Trading Bot — Environment Variables
#
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Kalshi API ─────────────────────────────────────────────────────────────
# Generate at: https://kalshi.com/account/api
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=/path/to/private_key.pem
KALSHI_ENV=demo   # "demo" for paper trading, "prod" for real money

# ── Claude API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Tuning (optional — defaults are sane) ──────────────────────────────────
# BANKROLL=100
# CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001    # cheap pre-screen (~$0.001/call)
# CLAUDE_MODEL_DEEP=claude-sonnet-4-20250514     # full analysis (~$0.01/call)
# MIN_EDGE_GAP=0.07
# MIN_BOOK_DEPTH=500
# MIN_MARKET_VOLUME=50000
# MAX_KELLY=0.25
# DISABLED_CATEGORIES=sports

# ── Loop timing (cost control) ─────────────────────────────────────────────
# SCAN_INTERVAL=1800     # 30 min — scanner runs often (free)
# BRAIN_INTERVAL=7200    # 2 hours — Claude runs less often (costs $)
# EXIT_INTERVAL=30       # 30 sec — exit checks are free
# CACHE_TTL=3600         # 1 hour — skip re-analyzing unchanged markets
